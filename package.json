{
  "name": "vdistortion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier . --write",
    "public": "ng build --base-href /vdistortion/ && cd dist/vdistortion/browser && cp index.html 404.html && gh-pages -d . -t --nojekyll",
    "to-webp": "npx to-static-images@latest json=source width=1000 height=1000"
  },
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@mdi/js": "^7.4.47",
    "@tsparticles/angular": "^3.0.0",
    "@tsparticles/preset-links": "^3.2.0",
    "@twogate/ngx-photo-gallery": "^1.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "gh-pages": "^6.3.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.2"
  }
}
